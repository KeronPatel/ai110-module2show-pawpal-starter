classDiagram
    class Task {
        +String description
        +String time
        +int duration
        +String priority
        +String frequency
        +bool completed
        +mark_complete()
    }
    class Pet {
        +String name
        +String species
        +List tasks
        +add_task(task)
        +get_tasks()
    }
    class Owner {
        +String name
        +List pets
        +add_pet(pet)
        +get_all_tasks()
    }
    class Scheduler {
        +Owner owner
        +sort_by_time()
        +filter_by_status(completed)
        +detect_conflicts()
    }
    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Scheduler --> Owner : reads from